#include <iostream> // Подключение библиотеки ввода и вывода
#include <string>   // Подключение библиотеки для работы со строками

using namespace std; // Использование пространства имен std

int main()
{
    string text; // Переменная для хранения текста
    int key;     // Переменная для хранения ключа

    cout << "enter text: "; // Вывод сообщения
    cin >> text; // Ввод текста

    cout << "enter key: "; // Запрос ключа
    cin >> key; // Ввод ключа

    // Проход по всем символам строки
    for (int i = 0; i < text.length(); i++)
    {
        // Смещение символа
        text[i] = text[i] + key;
    }

    cout << "secret text: " << text; // Вывод результата

    return 0; // Завершение программы
}
